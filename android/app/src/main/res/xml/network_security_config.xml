<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext (HTTP) only to the local server addresses used in development
         and at runtime (localhost, loopback, and the Android emulator host alias).
         All other traffic must use HTTPS. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!-- 10.0.2.2 is the host loopback alias inside the Android emulator -->
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

    <!-- Default: block cleartext, trust only system (pre-installed) CA certificates -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
