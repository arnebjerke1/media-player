# ─── CinemaBox – Environment Variables ────────────────────────────────────────
#
# Copy this file to .env and fill in your API keys.
# Both keys are FREE to obtain (see README for instructions).

# TMDB API key  →  https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# OMDB API key  →  https://www.omdbapi.com/apikey.aspx  (needed for Rotten Tomatoes score)
OMDB_API_KEY=

# Port the server listens on (default: 3000)
PORT=3000
